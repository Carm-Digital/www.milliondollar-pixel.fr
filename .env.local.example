# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Admin (email allowed to access /admin after Supabase login)
ADMIN_EMAIL=admin@example.com

# Mot de passe d’accès au panneau (page /admin). Si défini, /admin redirige vers /admin/connexion tant que le cookie n’est pas posé.
# Optionnel mais fortement recommandé en production. Générez une longue chaîne aléatoire.
ADMIN_ACCESS_PASSWORD=

# Optionnel : secret HMAC pour le cookie de porte (sinon dérivé de ADMIN_ACCESS_PASSWORD)
# ADMIN_GATE_SECRET=
